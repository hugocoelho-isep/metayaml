@startuml github_actions
!theme plain
skinparam classAttributeIconSize 0
skinparam classFontStyle bold

class GithubActions{
  + name : STRING [0..1]
  + env : Map<String, String> [0..1]
}

class On{
  + branch_protection_rule : STRING [0..1]
}

class Push{
  + branches : STRING [0..*]
  + tags : STRING [0..*]
}

class Pull_request{
  + branches : STRING [0..*]
  + types : STRING [0..*]
}

class Job{
  + id : STRING [1..1]
  + runs_on : STRING [0..1]
  + name : STRING [0..1]
  + needs : STRING [0..1]
  + if : STRING [0..1]
  + uses : STRING [0..1]
  + with : Map<String, String> [0..1]
  + env : Map<String, String> [0..1]
}

class Step{
  + name : STRING [0..1]
  + uses : STRING [0..1]
  + run : STRING [0..1]
  + id : STRING [0..1]
  + if : STRING [0..1]
  + working_directory : STRING [0..1]
  + shell : STRING [0..1]
  + continue_on_error : BOOLEAN [0..1]
  + timeout_minutes : INTEGER [0..1]
  + with : Map<String, String> [0..1]
  + env : Map<String, String> [0..1]
}

class Permissions{
  + contents : STRING [0..1]
  + security_events : STRING [0..1]
  + actions : STRING [0..1]
  + pages : STRING [0..1]
  + id_token : STRING [0..1]
  + pull_requests : STRING [0..1]
  + issues : STRING [0..1]
  + packages : STRING [0..1]
  + models : STRING [0..1]
  + checks : STRING [0..1]
}

class Schedule{
  + cron : STRING [1..1]
}

class Environment{
  + name : STRING [1..1]
  + url : STRING [0..1]
}

class Concurrency{
  + group : STRING [1..1]
  + cancel_in_progress : BOOLEAN [1..1]
}

class Strategy{
  + fail_fast : BOOLEAN [0..1]
  + max_parallel : INTEGER [0..1]
}

class Matrix{
  + os : STRING [0..*]
  + build_type : STRING [0..*]
  + c_compiler : STRING [0..*]
  + otp : STRING [0..*]
  + elixir : STRING [0..*]
  + python_version : FLOAT [0..*]
  + configuration : STRING [0..*]
  + node_version : STRING [0..*]
  + r_version : STRING [0..*]
  + ruby_version : STRING [0..*]
}

class Include{
  + os : STRING [1..1]
  + c_compiler : STRING [1..1]
  + cpp_compiler : STRING [1..1]
}

class Exclude{
  + os : STRING [1..1]
  + c_compiler : STRING [1..1]
}

class Secret{
  + id : STRING [1..1]
  + required : BOOLEAN [1..1]
}

class Container{
  + image : STRING [1..1]
}

class Defaults{
}

class Run{
  + shell : STRING [1..1]
}

class Release{
  + types : STRING [0..*]
}

class Outputs{
  + digests : STRING [0..1]
  + image_tag : STRING [0..1]
  + ROUTE : STRING [0..1]
  + SELECTOR : STRING [0..1]
}

class Input{
  + id : STRING [1..1]
  + description : STRING [1..1]
  + default : STRING [1..1]
  + required : BOOLEAN [1..1]
  + type : STRING [1..1]
}

class Merge_group{
  + branches : STRING [0..*]
}

class Service{
  + id : STRING [1..1]
  + image : STRING [1..1]
  + ports : STRING [0..*]
  + env : Map<String, String> [0..1]
}

class Issues{
  + types : STRING [0..*]
}

GithubActions *--> "0..1" On : on
GithubActions *--> "1..*" Job : jobs
GithubActions *--> "0..1" Permissions : permissions
GithubActions *--> "0..1" Concurrency : concurrency
GithubActions *--> "0..1" Defaults : defaults
On *--> "0..1" Push : push
On *--> "0..1" Pull_request : pull_request
On *--> "0..*" Schedule : schedule
On *--> "0..*" Secret : workflow_call
On *--> "0..1" Pull_request : pull_request_target
On *--> "0..1" Release : release
On *--> "0..*" Input : workflow_dispatch
On *--> "0..1" Merge_group : merge_group
On *--> "0..1" Issues : issues
Job *--> "0..*" Step : steps
Job *--> "0..1" Permissions : permissions
Job *--> "0..1" Environment : environment
Job *--> "0..1" Strategy : strategy
Job *--> "0..1" Container : container
Job *--> "0..1" Outputs : outputs
Job *--> "0..*" Service : services
Job *--> "0..1" Defaults : defaults
Strategy *--> "0..1" Matrix : matrix
Matrix *--> "0..*" Include : include
Matrix *--> "0..*" Exclude : exclude
Defaults *--> "1..1" Run : run

@enduml
