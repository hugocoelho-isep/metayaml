@startuml github_actions
!theme plain
skinparam classAttributeIconSize 0
skinparam classFontStyle bold

class GithubActions{
  + name : STRING [1..1]
}

class Jobs{
}

class Build{
  + runs-on : STRING [1..1]
}

class Step{
  + name : STRING [1..1]
  + uses : STRING [0..1]
  + run : STRING [0..1]
}

class With{
  + java-version : STRING [0..1]
  + distribution : STRING [0..1]
  + name : STRING [0..1]
  + path : STRING [0..1]
  + files : STRING [0..1]
  + generate_release_notes : BOOLEAN [0..1]
}

class On{
}

class Push{
  + branches : STRING [0..*]
  + tags : STRING [0..*]
}

class Pull_request{
  + branches : STRING [0..*]
}

class Release{
  + runs-on : STRING [1..1]
}

class Permissions{
  + contents : STRING [1..1]
}

GithubActions --> "0..1" Jobs : jobs
GithubActions --> "0..1" On : on
Jobs --> "0..1" Build : build
Jobs --> "0..1" Build : lint
Jobs --> "0..1" Release : release
Build *--> [0..*] Step : steps
Step --> "0..1" With : with
On --> "0..1" Push : push
On --> "0..1" Pull_request : pull_request
Release --> "1..1" Permissions : permissions
Release *--> [0..*] Step : steps

@enduml
