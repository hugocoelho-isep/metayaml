@startuml github_actions
!theme plain
skinparam classAttributeIconSize 0
skinparam classFontStyle bold

class GithubActions{
  + name : STRING [1..1]
}

class On{
}

class Push{
  + branches : STRING [0..*]
  + tags : STRING [0..*]
}

class Pull_request{
  + branches : STRING [0..*]
}

class Job{
  + id : STRING [1..1]
  + runs_on : STRING [1..1]
  + needs : STRING [0..*]
}

class Step{
  + name : STRING [1..1]
  + uses : STRING [0..1]
  + run : STRING [0..1]
}

class With{
  + java_version : STRING [0..1]
  + distribution : STRING [0..1]
  + name : STRING [0..1]
  + path : STRING [0..1]
  + target : STRING [0..1]
  + token : STRING [0..1]
  + files : STRING [0..1]
  + generate_release_notes : BOOLEAN [0..1]
}

class Permissions{
  + contents : STRING [1..1]
}

GithubActions *--> "1..1" On : on
GithubActions *--> "1..*" Job : jobs
On *--> "0..1" Push : push
On *--> "0..1" Pull_request : pull_request
Job *--> "1..*" Step : steps
Job *--> "0..1" Permissions : permissions
Step *--> "0..1" With : with

@enduml
