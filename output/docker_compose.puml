@startuml docker_compose
!theme plain
skinparam classAttributeIconSize 0
skinparam classFontStyle bold

class DockerCompose{
  + version : STRING [0..1]
  + name : STRING [0..1]
}

class Service{
  + id : STRING [1..1]
  + ports : STRING [0..*]
  + image : STRING [0..1]
  + restart : STRING [0..1]
  + container_name : STRING [0..1]
  + command : STRING [0..*]
  + stop_signal : STRING [0..1]
  + expose : INTEGER [0..*]
  + secrets : STRING [0..*]
  + user : STRING [0..1]
  + hostname : STRING [0..1]
  + cap_add : STRING [0..*]
  + network_mode : STRING [0..1]
  + stdin_open : BOOLEAN [0..1]
  + labels : STRING [0..*]
  + platform : STRING [0..1]
  + runtime : STRING [0..1]
  + sysctls : STRING [0..*]
  + environment : Map<String, String> [0..1]
}

abstract class Build{
}

class Healthcheck{
  + test : STRING [1..*]
  + interval : STRING [1..1]
  + retries : INTEGER [1..1]
  + start_period : STRING [0..1]
  + timeout : STRING [0..1]
}

abstract class Networks{
}

class Network{
  + id : STRING [1..1]
  + driver : STRING [0..1]
  + ipv4_address : STRING [0..1]
}

abstract class Volume{
}

class Resource{
  + id : STRING [1..1]
  + memory : STRING [1..1]
}

class Secret{
  + id : STRING [1..1]
  + file : STRING [1..1]
}

abstract class Depends_on{
}

class Db{
  + condition : STRING [1..1]
}

class Config{
  + subnet : STRING [1..1]
}

class VolumeObject{
  + id : STRING [0..1]
  + type : STRING [0..1]
  + source : STRING [0..1]
  + target : STRING [0..1]
  + read_only : BOOLEAN [0..1]
}

class VolumeValue{
  + value : STRING [1..*]
}

class BuildObject{
  + context : STRING [1..1]
  + target : STRING [0..1]
  + args : STRING [0..*]
  + dockerfile : STRING [0..1]
}

class BuildValue{
  + value : STRING [1..1]
}

class NetworksObject{
}

class NetworksValue{
  + value : STRING [1..*]
}

class Depends_onObject{
}

class Depends_onValue{
  + value : STRING [1..*]
}

Volume <|-- VolumeObject
Volume <|-- VolumeValue
Build <|-- BuildObject
Build <|-- BuildValue
Networks <|-- NetworksObject
Networks <|-- NetworksValue
Depends_on <|-- Depends_onObject
Depends_on <|-- Depends_onValue

DockerCompose *--> "1..*" Service : services
DockerCompose *--> "0..1" Networks : networks
DockerCompose *--> "0..*" Volume : volumes
DockerCompose *--> "0..*" Secret : secrets
Service *--> "0..1" Build : build
Service *--> "0..1" Healthcheck : healthcheck
Service *--> "0..*" Resource : deploy
Service *--> "0..1" Depends_on : depends_on
Service *--> "0..*" Volume : volumes
Service *--> "0..1" Networks : networks
Network *--> "0..*" Config : ipam
NetworksObject *--> "1..*" Network : network
Depends_onObject *--> "1..1" Db : db

@enduml
