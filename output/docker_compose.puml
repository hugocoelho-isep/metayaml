@startuml docker_compose
!theme plain
skinparam classAttributeIconSize 0
skinparam classFontStyle bold

class DockerCompose{
  + version : STRING [1..1]
}

class Service{
  + id : STRING [1..1]
  + image : STRING [1..1]
  + ports : STRING [0..*]
  + restart : STRING [0..1]
}

class Volume{
  + id : STRING [1..1]
}

class Environment{
  + POSTGRES_DB : STRING [0..1]
  + POSTGRES_USER : STRING [0..1]
  + POSTGRES_PASSWORD : STRING [0..1]
  + GF_SECURITY_ADMIN_USER=admin : STRING [0..1]
  + GF_SECURITY_ADMIN_PASSWORD=admin : STRING [0..1]
  + SPRING_DATASOURCE_URL=jdbc:postgresql://db:5432/mydb : STRING [0..1]
  + SPRING_DATASOURCE_USERNAME=admin : STRING [0..1]
  + SPRING_DATASOURCE_PASSWORD=secret : STRING [0..1]
}

class Depends_on{
  + prometheus : STRING [0..1]
}

class Build{
  + context : STRING [1..1]
  + dockerfile : STRING [1..1]
}

class Db{
  + condition : STRING [1..1]
}

class Healthcheck{
  + interval : STRING [1..1]
  + timeout : STRING [1..1]
  + retries : INTEGER [1..1]
}

class Test{
  + CMD : STRING [0..1]
  + pg_isready : STRING [0..1]
  + _U : STRING [0..1]
  + admin : STRING [0..1]
}

DockerCompose *--> "1..*" Service : services
DockerCompose *--> "0..*" Volume : volumes
Service *--> "0..*" Volume : volumes
Service *--> "0..1" Environment : environment
Service *--> "0..1" Depends_on : depends_on
Service *--> "0..1" Build : build
Service *--> "0..1" Healthcheck : healthcheck
Depends_on *--> "0..1" Db : db
Healthcheck *--> "1..1" Test : test

@enduml
