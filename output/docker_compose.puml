@startuml docker_compose
!theme plain
skinparam classAttributeIconSize 0
skinparam classFontStyle bold

class DockerCompose{
  + version : STRING [1..1]
}

class Services{
}

class Service{
  + image : STRING [1..1]
  + ports : STRING [0..*]
  + volumes : STRING [0..*]
  + restart : STRING [0..1]
  + environment : STRING [0..*]
  + depends_on : STRING [0..*]
}

class Volumes{
  + prometheus-data : STRING [0..1]
  + grafana-data : STRING [0..1]
  + db-data : STRING [0..1]
}

class Build{
  + context : STRING [1..1]
  + dockerfile : STRING [1..1]
}

class Depends_on{
}

class Db{
  + condition : STRING [1..1]
}

class Environment{
  + POSTGRES_DB : STRING [1..1]
  + POSTGRES_USER : STRING [1..1]
  + POSTGRES_PASSWORD : STRING [1..1]
}

class Healthcheck{
  + test : STRING [0..*]
  + interval : STRING [1..1]
  + timeout : STRING [1..1]
  + retries : INTEGER [1..1]
}

DockerCompose *--> "1..1" Services : services
DockerCompose *--> "1..1" Volumes : volumes
Services *--> "1..*" Service : service
Service *--> "0..1" Build : build
Service *--> "0..1" Depends_on : depends_on
Service *--> "0..1" Environment : environment
Service *--> "0..1" Healthcheck : healthcheck
Depends_on *--> "1..1" Db : db

@enduml
