  + group : STRING [0..1]
  + force : BOOLEAN [0..1]
  + content : STRING [0..1]
}

class Docker_container{
  + name : STRING [1..1]
  + state : STRING [0..1]
  + image : STRING [0..1]
  + command : STRING [0..1]
}

