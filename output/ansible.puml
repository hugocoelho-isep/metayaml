  + image_name : STRING [0..1]
  + ansible_install_method : STRING [0..1]
  + jenkins_plugins : STRING [0..*]
  + aws_profile : STRING [0..1]
  + aws_region : STRING [0..1]
  + aws_ec2_ami : STRING [0..1]
  + node_apps_location : STRING [0..1]
  + app_port : INTEGER [0..1]
  + app_user : STRING [0..1]
  + app_dir : STRING [0..1]
  + firewall_enable_ipv6 : BOOLEAN [0..1]
  + pip_install_packages : STRING [0..*]
  + ansible_python_interpreter : STRING [0..1]
}

class Assert{
  + that : STRING [1..1]
}

class Pause{
  + seconds : INTEGER [1..1]
}

class Pre_task{
  + name : STRING [1..1]
