}

class Archive{
  + path : STRING [1..1]
  + dest : STRING [1..1]
  + format : STRING [1..1]
  + remove : BOOLEAN [1..1]
}

class Find{
  + paths : STRING [1..1]
  + age : STRING [1..1]
  + patterns : STRING [1..1]
}

class Vars{
  + backup_dir : STRING [0..1]
  + db_name : STRING [0..1]
  + db_user : STRING [0..1]
  + retention_days : INTEGER [0..1]
  + my_color_choice : STRING [0..1]
  + nodejs_install_npm_user : STRING [0..1]
  + npm_config_prefix : STRING [0..1]
  + nodejs_npm_global_packages : STRING [0..*]
  + firewall_allowed_tcp_ports : STRING [0..*]
  + build_root : STRING [0..1]
  + base_image : STRING [0..1]
  + container_name : STRING [0..1]
