}

class Post_task{
  + name : STRING [1..1]
  + delegate_to : STRING [0..1]
  + with_items : STRING [0..1]
  + shell : STRING [0..1]
  + command : STRING [0..1]
}

class Wait_for{
  + host : STRING [1..1]
  + port : INTEGER [1..1]
  + state : STRING [1..1]
  + timeout : INTEGER [1..1]
}

class Git{
  + repo : STRING [1..1]
  + version : STRING [1..1]
  + dest : STRING [1..1]
