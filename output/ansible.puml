@startuml ansible
!theme plain
skinparam classAttributeIconSize 0
skinparam classFontStyle bold

class Ansible{
  + hosts : STRING [0..1]
  + become : BOOLEAN [0..1]
  + name : STRING [0..1]
  + serial : INTEGER [0..1]
  + vars_files : STRING [0..*]
  + gather_facts : BOOLEAN [0..1]
  + connection : STRING [0..1]
  + remote_user : STRING [0..1]
  + import_playbook : STRING [0..1]
}

class Task{
  + name : STRING [0..1]
  + command : STRING [0..1]
  + become_user : STRING [0..1]
  + register : STRING [0..1]
  + loop : STRING [0..1]
  + notify : STRING [0..1]
  + become : BOOLEAN [0..1]
  + when : STRING [0..1]
  + environment : STRING [0..1]
  + npm : STRING [0..1]
  + changed_when : BOOLEAN [0..1]
  + import_tasks : STRING [0..1]
  + shell : STRING [0..1]
  + apt_repository : STRING [0..1]
  + apache2_module : STRING [0..1]
  + mysql_db : STRING [0..1]
  + run_once : BOOLEAN [0..1]
