  + name : STRING [0..1]
  + command : STRING [0..1]
  + service : STRING [0..1]
  + import_tasks : STRING [0..1]
}

class Role{
  + role : STRING [0..1]
  + name : STRING [0..1]
  + delegate_to : STRING [0..1]
  + tags : STRING [0..*]
}

class Set_fact{
